# ──────────────────────────────────────────────
# Environment files:
#   .env              — fallback / shared defaults
#   .env.development  — loaded by default (hardhat commands)
#   .env.production   — loaded by `npm run deploy:bsc`
# Each file should contain ALL fields for that env.
# ──────────────────────────────────────────────

# ── .env.development ─────────────────────────
PRIVATE_KEY=
BSC_TESTNET_RPC_URL=https://bsc-testnet-dataseed.bnbchain.org
BSCSCAN_API_KEY=

# ── .env.production ──────────────────────────
# PRIVATE_KEY=your-wallet-private-key-without-0x-prefix
# BSC_TESTNET_RPC_URL=https://bsc-testnet-dataseed.bnbchain.org
# BSCSCAN_API_KEY=your-bscscan-explorer-api-key
