# ──────────────────────────────────────────────
# Environment files:
#   .env              — fallback / shared defaults
#   .env.development  — loaded when NODE_ENV=development (default)
#   .env.production   — loaded when NODE_ENV=production
# Each file should contain ALL fields for that env.
# ──────────────────────────────────────────────

# ── .env.development ─────────────────────────
NODE_ENV=development
PORT=3000
NETWORK=localhost
DATABASE_URL=postgresql://user:password@localhost:5432/ticketchain
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=7d
TICKET_NFT_CONTRACT_ADDRESS=0x
EVENT_FACTORY_CONTRACT_ADDRESS=0x
ADMIN_WALLET_ADDRESS=0x

# ── .env.production ──────────────────────────
# NODE_ENV=production
# PORT=3000
# NETWORK=bscTestnet
# DATABASE_URL=postgresql://user:password@localhost:5432/ticketchain
# JWT_SECRET=your-super-secret-jwt-key
# JWT_EXPIRES_IN=7d
# TICKET_NFT_CONTRACT_ADDRESS=0x
# EVENT_FACTORY_CONTRACT_ADDRESS=0x
# ADMIN_WALLET_ADDRESS=0x
