# ──────────────────────────────────────────────
# Environment files:
#   .env              — fallback / shared defaults
#   .env.development  — loaded by `vite dev`
#   .env.production   — loaded by `vite build`
# Each file should contain ALL fields for that env.
# ──────────────────────────────────────────────

# VITE_NETWORK        — "localhost" or "bscTestnet"
# VITE_API_BASE_URL   — backend API base URL
# VITE_CHAIN_ID       — 31337 (localhost) or 97 (bscTestnet)
# VITE_TICKET_NFT_ADDRESS      — deployed TicketNFT contract
# VITE_EVENT_FACTORY_ADDRESS   — deployed EventFactory contract

# ── .env.development ─────────────────────────
VITE_NETWORK=localhost
VITE_API_BASE_URL=http://localhost:3000/api
VITE_CHAIN_ID=31337
VITE_TICKET_NFT_ADDRESS=0x
VITE_EVENT_FACTORY_ADDRESS=0x

# ── .env.production ──────────────────────────
# VITE_NETWORK=bscTestnet
# VITE_API_BASE_URL=http://localhost:3000/api
# VITE_CHAIN_ID=97
# VITE_TICKET_NFT_ADDRESS=0x
# VITE_EVENT_FACTORY_ADDRESS=0x
