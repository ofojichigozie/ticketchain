# Ignore Node module folders across all packages
**/node_modules/

# Ignore build artifacts
**/dist/
**/build/
**/coverage/
**/.cache/
**/.vite/
**/artifacts/
**/cache/
**/typechain-types/

# Ignore environment and log files
.env
.env.development
.env.production
.env.local
.env.test
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Ignore editor and OS files
.vscode/
.DS_Store
Thumbs.db

# Ignore package manager lock files if generated locally
package-lock.json
yarn.lock
pnpm-lock.yaml

# Exclude docs and journal folders from the repo
_project-docs_/
journal/
